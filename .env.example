# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
APP_DOMAIN=localhost

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=education
POSTGRES_USER=education
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgresql://education:change-me@postgres:5432/education

# ── Backend ───────────────────────────────────────────────────────────────────
BACKEND_PORT=4000
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info

# ── Frontend dev ──────────────────────────────────────────────────────────────
FRONTEND_PORT=5173
# Used by Vite proxy in Docker dev; defaults to http://localhost:4000 outside Docker
VITE_API_BASE_URL=http://backend:4000

# ── JWT (Phase 2) ─────────────────────────────────────────────────────────────
# RS256 key pair — generate with:
#   openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
#   openssl rsa -pubout -in private.pem -out public.pem
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30

# ── Cookies (Phase 2) ─────────────────────────────────────────────────────────
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
CSRF_SECRET=

# ── AWS ───────────────────────────────────────────────────────────────────────
# EC2 IAM role is used for authentication — do NOT set static keys here.
AWS_REGION=ap-south-1
S3_ASSETS_BUCKET=
S3_PRIVATE_BUCKET=

# ── Azure AI Speech (Phase 5) ─────────────────────────────────────────────────
# TTS_PROVIDER: mock | azure
TTS_PROVIDER=mock
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=

# ── pgAdmin (dev, tools profile) ─────────────────────────────────────────────
PGADMIN_EMAIL=admin@education.local
PGADMIN_PASSWORD=change-me
