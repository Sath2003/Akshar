{
  "name": "education-platform",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend",
    "shared",
    "content"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=@education/frontend",
    "dev:backend": "npm run dev --workspace=@education/backend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate-content": "npm run validate --workspace=@education/content"
  },
  "devDependencies": {
    "@eslint/js": "9.27.0",
    "eslint": "9.27.0",
    "eslint-plugin-react": "7.37.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-react-refresh": "0.4.19",
    "globals": "16.2.0",
    "prettier": "3.4.2"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10"
  },
  "dependencies": {
    "vitest": "4.1.10"
  }
}
